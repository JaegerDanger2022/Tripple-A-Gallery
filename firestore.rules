rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Artworks — public read, no client writes (all writes go through Admin SDK / server)
    match /artworks/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // Categories — public read, no client writes
    match /categories/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // Admins — a user can only read their own admin doc (to check if they have access)
    match /admins/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
