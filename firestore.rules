rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Artworks — public read, admin write
    match /artworks/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Categories — public read, admin write
    match /categories/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Frames — public read, admin write
    match /frames/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Formats — public read, admin write
    match /formats/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Settings (shipping fee, etc.) — public read (checkout shows the fee),
    // admin write. The server recomputes shipping from here too (Admin SDK).
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Admins — a user can only read their own doc
    match /admins/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // Users (tiered access) — a signed-in user owns their own profile doc.
    //  • read: only your own profile (admins read all, e.g. the admin Users page).
    //  • create: only your own doc, and ONLY at tier 0. This lets the client
    //    self-provision on first sign-in without being able to grant paid tiers.
    //  • update: a user may edit their own non-privileged fields, but NEVER
    //    change `tier` — that's set by the server (Stripe fulfilment via the
    //    Admin SDK, which bypasses rules) or by an admin (the admin Users page).
    //  • delete: never from the client.
    match /users/{uid} {
      allow read: if isAdmin() ||
        (request.auth != null && request.auth.uid == uid);
      allow create: if request.auth != null &&
        request.auth.uid == uid &&
        request.resource.data.tier == 0;
      allow update: if isAdmin() ||
        (request.auth != null &&
         request.auth.uid == uid &&
         request.resource.data.tier == resource.data.tier &&
         request.resource.data.get('adminTierLock', false) ==
           resource.data.get('adminTierLock', false));
      allow delete: if false;
    }

    // Orders — a buyer may read their own orders; admins read all. Orders are
    // created and updated ONLY server-side via the Admin SDK (Stripe checkout +
    // fulfilment), which bypasses these rules. The client can never write an
    // order, so an unpaid cart can't be forged into a "paid" order (which would
    // otherwise unlock digital downloads). The download gate also reads orders
    // server-side via the Admin SDK.
    match /orders/{orderId} {
      allow read: if isAdmin() ||
        (request.auth != null && resource.data.userId == request.auth.uid);
      allow create, update, delete: if false;
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
